{
  "name": "mimo-remote-cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CLI wrapper to connect MiMo Code to Android app",
  "main": "dist/index.js",
  "bin": {
    "mimo-remote": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "ws": "^8.17.0",
    "node-pty": "^1.0.0",
    "chokidar": "^3.6.0",
    "libsodium-wrappers": "^0.7.13",
    "qrcode-terminal": "^0.12.0",
    "commander": "^12.1.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@types/ws": "^8.5.10",
    "@types/libsodium-wrappers": "^0.7.13",
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "tsx": "^4.16.0"
  }
}
